# Leave empty — Vite proxy handles /api/* in dev (proxied to Express :3001)
VITE_API_BASE_URL=
VITE_INVITE_BASE_URL=http://localhost:8081

# Express BFF server settings
BACKEND_URL=http://localhost:8081
BACKEND_PUBLIC_URL=http://localhost:8081
PORT=3001
# Must match ADMIN_AUTH_TOKEN in the controller — used by the BFF to proxy admin API calls
ADMIN_AUTH_TOKEN=7f8e91a2b3c4d5e6f7a8b9c0d1e2f3a4
