{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts", "lib/proxy.ts", "lib/db.ts"]
}
