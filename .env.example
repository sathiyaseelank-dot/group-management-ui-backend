# ── General ──────────────────────────────────────────────────────────────────
TRUST_DOMAIN=mycorp.internal

# ── Controller ───────────────────────────────────────────────────────────────
CONTROLLER_ADDR=127.0.0.1:8443
ADMIN_HTTP_ADDR=:8081
# Second listener for OAuth callbacks (must match redirect URIs in Google Console)
OAUTH_CALLBACK_ADDR=:8080

# Tokens / secrets
ADMIN_AUTH_TOKEN=<32-char hex token>
INTERNAL_API_TOKEN=<64-char hex token>
POLICY_SIGNING_KEY=<64-char hex token — defaults to INTERNAL_API_TOKEN>
JWT_SECRET=<random secret>

# Policy TTL (seconds, default 600)
POLICY_SNAPSHOT_TTL_SECONDS=600

# Database (leave DATABASE_URL empty to use SQLite via DB_PATH)
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable
DB_PATH=ztna.db
DEVICE_CA_DIR=

# ── OAuth / Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
USER_OAUTH_REDIRECT_URL=http://localhost:8080/oauth/google/callback
ADMIN_OAUTH_REDIRECT_URL=http://localhost:8080/oauth/google/callback

# ── URLs ──────────────────────────────────────────────────────────────────────
INVITE_BASE_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to log in as admin via OAuth
ADMIN_LOGIN_EMAILS=admin@example.com

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ZTNA <noreply@example.com>

# ── Connector ─────────────────────────────────────────────────────────────────
CONNECTOR_ID=
CONNECTOR_LISTEN_ADDR=
ENROLLMENT_TOKEN=
POLICY_STALE_GRACE_SECONDS=
CONTROLLER_CA_PATH=
CREDENTIALS_DIRECTORY=

# ── Tunneler ──────────────────────────────────────────────────────────────────
TUNNELER_ID=
CONNECTOR_ADDR=
