# Controller configuration — copy to .env and fill in values
#   cp .env.example .env

# ── General ───────────────────────────────────────────────────────────────────
TRUST_DOMAIN=mycorp.internal

# ── Controller ────────────────────────────────────────────────────────────────
CONTROLLER_ADDR=localhost:8443
ADMIN_HTTP_ADDR=0.0.0.0:8081

# Tokens / secrets (generate with: openssl rand -hex 32)
ADMIN_AUTH_TOKEN=<random-token>
INTERNAL_API_TOKEN=<random-token>
POLICY_SIGNING_KEY=<random-token>
JWT_SECRET=<random-secret>

# Policy TTL (seconds, default 600)
POLICY_SNAPSHOT_TTL_SECONDS=600

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use SQLite via DB_PATH.
# Quick start: docker compose up -d  (from project root) then use the URL below.
DATABASE_URL=postgres://ztnaadmin:inkztnapass@localhost:5432/ztna?sslmode=disable
DB_PATH=controller.db

# ── OAuth / Google (leave GOOGLE_CLIENT_ID empty to disable) ──────────────────
GOOGLE_CLIENT_ID=<your-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-oauth-client-secret>
OAUTH_REDIRECT_URL=http://localhost:8080/oauth/google/callback
OAUTH_CALLBACK_ADDR=:8080

# ── URLs ──────────────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
INVITE_BASE_URL=http://localhost:8081

# ── Access control ────────────────────────────────────────────────────────────
ADMIN_LOGIN_EMAILS=admin@example.com,other@example.com

# ── SMTP (leave SMTP_HOST empty to disable, invite URL logged instead) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=<gmail-app-password>
SMTP_FROM=youremail@gmail.com
