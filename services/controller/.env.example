# Controller Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# NEVER commit the .env file — it is gitignored.

# Required
DATABASE_URL=postgres://ztnaadmin:<POSTGRES_PASSWORD>@localhost:5432/ztna?sslmode=disable
INTERNAL_CA_CERT=<paste PEM CA cert or use: $(cat ca/ca.crt)>
INTERNAL_CA_KEY=<paste PEM CA key or use: $(cat ca/ca.pkcs8.key)>
ADMIN_AUTH_TOKEN=<run: openssl rand -hex 16>
INTERNAL_API_TOKEN=<run: openssl rand -hex 32>
JWT_SECRET=<run: openssl rand -hex 32>

# Networking
TRUST_DOMAIN=mycorp.internal
CONTROLLER_ADDR=localhost:8443
ADMIN_HTTP_ADDR=0.0.0.0:8081
# OAUTH_CALLBACK_ADDR=:8080

# OAuth (Google) — Admin dashboard login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OAUTH_REDIRECT_URL=http://localhost:8080/oauth/google/callback

# OAuth (Google) — Client PKCE flows (device auth, invite)
# CLIENT_GOOGLE_CLIENT_ID=
# CLIENT_GOOGLE_CLIENT_SECRET=
# CLIENT_OAUTH_REDIRECT_URL=http://localhost:8080/api/invite/callback

# OAuth (GitHub)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URL=

# Frontend
DASHBOARD_URL=http://localhost:3000
INVITE_BASE_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000

# Email (for invites)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Security
# IDP_ENCRYPTION_KEY=<run: openssl rand -hex 16>
# SECURE_COOKIES=false
# ADMIN_LOGIN_EMAILS=admin@example.com
